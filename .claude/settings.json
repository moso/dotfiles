{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Read(./.gitignore)",
      "Read(./eslint.config.*)",
      "Read(./package.json)",
      "Read(./README.md)",
      "Read(./CLAUDE.md)",
      "Read(./PROJECT.md)",
      "Read(./tsconfig.json)",
      "Read(./src/**)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(git commit)",
      "Bash(git fetch)",
      "Bash(git pull)",
      "Bash(git push)",
      "Read(./.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./build)",
      "Read(./dist)",
      "Read(./.personal-dictionary.txt)"
    ]
  },
  "model": "sonnet",
  "forceLoginMethod": "claudeai",
  "learnMode": false,
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "enabledPlugins": {
    "context-mode@context-mode": true
  }
}
